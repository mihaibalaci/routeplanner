{
  "name": "route-planner-platform",
  "version": "1.0.0",
  "description": "Route Planner Web Platform - Multi-stop route planning for Europe",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint 'src/**/*.ts'",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "migrate:up": "node-pg-migrate up",
    "migrate:down": "node-pg-migrate down",
    "migrate:create": "node-pg-migrate create"
  },
  "dependencies": {
    "@googlemaps/google-maps-services-js": "3.4.0",
    "apple-signin-auth": "2.0.0",
    "bcrypt": "6.0.0",
    "cors": "2.8.5",
    "dotenv": "16.4.7",
    "express": "4.22.1",
    "express-validator": "7.3.2",
    "google-auth-library": "9.15.1",
    "helmet": "8.0.0",
    "jsonwebtoken": "9.0.2",
    "node-pg-migrate": "7.9.1",
    "pg": "8.13.3",
    "redis": "4.7.0",
    "uuid": "11.1.1"
  },
  "devDependencies": {
    "@types/bcrypt": "5.0.2",
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/jsonwebtoken": "9.0.9",
    "@types/node": "22.15.3",
    "@types/pg": "8.11.11",
    "@types/supertest": "7.2.0",
    "@types/uuid": "10.0.0",
    "@typescript-eslint/eslint-plugin": "8.32.0",
    "@typescript-eslint/parser": "8.32.0",
    "eslint": "8.57.1",
    "fast-check": "3.23.2",
    "prettier": "3.5.3",
    "supertest": "7.2.2",
    "ts-node-dev": "2.0.0",
    "typescript": "5.8.3",
    "vitest": "3.1.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "glob": "^11.0.0",
    "rimraf": "^6.0.0"
  }
}
